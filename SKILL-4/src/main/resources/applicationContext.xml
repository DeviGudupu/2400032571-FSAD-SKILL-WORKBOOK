<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Constructor Injection -->
    <bean id="studentConstructor" class="com.example.student.Student">
        <constructor-arg value="101"/>
        <constructor-arg value="maha"/>
        <constructor-arg value="Spring Core"/>
        <constructor-arg value="2026"/>
    </bean>

    <!-- Pure Setter Injection -->
    <bean id="studentSetter" class="com.example.student.Student">
        <property name="studentId" value="102"/>
        <property name="name" value="Jane Smith"/>
        <property name="course" value="REST APIs"/>
        <property name="year" value="2027"/>
    </bean>

</beans>
